@* 네비게이션 메뉴 컴포넌트 *@
@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🏭 무역시스템</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        @* ── 기본 메뉴 ─────────────────────────── *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill me-2"></span> 홈
            </NavLink>
        </div>

        @* ── 로그인한 사용자만 보이는 메뉴 ───────── *@
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="orders">
                        <span class="bi bi-cart-fill me-2"></span> 발주관리
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="chat">
                        <span class="bi bi-chat-dots-fill me-2"></span> 채팅
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="files">
                        <span class="bi bi-folder-fill me-2"></span> 파일관리
                    </NavLink>
                </div>

                @* 구분선 *@
                <hr style="border-color:#ffffff33; margin:8px 16px;" />

                @* 현재 로그인 사용자 표시 *@
                <div class="px-3 mb-1" style="font-size:0.8em; color:#adb5bd;">
                    👤 @context.User.Identity?.Name
                </div>

                @* 로그아웃 버튼 *@
                <div class="nav-item px-3">
                    <form action="/Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/" />
                        <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start">
                            <span class="bi bi-box-arrow-left me-2"></span> 로그아웃
                        </button>
                    </form>
                </div>
            </Authorized>

            @* 비로그인 상태일 때 *@
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Register">
                        <span class="bi bi-person-plus-fill me-2"></span> 회원가입
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Login">
                        <span class="bi bi-box-arrow-in-right me-2"></span> 로그인
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>