@page "/files"
@using tradesystem.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject AuthenticationStateProvider Auth
@inject IWebHostEnvironment Env
@attribute [Authorize]
@rendermode InteractiveServer

<h3>📁 파일 업로드</h3>

<div style="border:1px solid #ddd; padding:16px; border-radius:8px;
            margin-bottom:20px; background:#f8f9fa;">
    <label class="form-label">파일 선택 (최대 10MB)</label>
    <InputFile OnChange="HandleFileSelected" class="form-control mb-3" />

    @if (uploading)
    {
        <div class="d-flex align-items-center gap-2 text-primary">
            <div class="spinner-border spinner-border-sm"></div>
            <span>업로드 중...</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success mt-2">@successMsg</div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger mt-2">@errorMsg</div>
    }
</div>

<h5>업로드된 파일 목록</h5>
@if (files.Count == 0)
{
    <p class="text-muted">업로드된 파일이 없습니다.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>파일명</th>
                <th>크기</th>
                <th>업로더</th>
                <th>업로드일</th>
                <th>다운로드</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in files)
            {
                <tr>
                    <td>@f.FileName</td>
                    <td>@(f.FileSize / 1024) KB</td>
                    <td>@f.UserId</td>
                    <td>@f.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a href="/uploads/@f.FileName" target="_blank"
                           class="btn btn-sm btn-outline-primary">다운로드</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<UploadedFile> files = new();
    bool uploading = false;
    string successMsg = "";
    string errorMsg = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadFiles();
    }

    async Task LoadFiles()
    {
        files = await Db.UploadedFiles
            .OrderByDescending(f => f.UploadedAt)
            .ToListAsync();
    }

    async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploading = true;
        successMsg = "";
        errorMsg = "";

        try
        {
            var file = e.File;

            if (file.Size > 10 * 1024 * 1024)
            {
                errorMsg = "파일 크기가 10MB를 초과합니다.";
                return;
            }

            var uploadDir = Path.Combine(Env.WebRootPath, "uploads");
            Directory.CreateDirectory(uploadDir);

            var safeName = Path.GetFileName(file.Name);
            var savePath = Path.Combine(uploadDir, safeName);

            await using var fs = new FileStream(savePath, FileMode.Create);
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(fs);

            var auth = await Auth.GetAuthenticationStateAsync();
            var userId = auth.User.Identity?.Name ?? "guest";

            Db.UploadedFiles.Add(new UploadedFile
            {
                FileName = safeName,
                FilePath = savePath,
                FileSize = file.Size,
                UploadedAt = DateTime.Now,
                UserId = userId
            });
            await Db.SaveChangesAsync();
            await LoadFiles();
            successMsg = $"{safeName} 업로드 완료!";
        }
        catch (Exception ex)
        {
            errorMsg = $"업로드 실패: {ex.Message}";
        }
        finally
        {
            uploading = false;
        }
    }
}